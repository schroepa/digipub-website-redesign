---
import Layout from "../../layouts/Layout.astro";
import { getCaseStudies, getAssetUrl } from "../../lib/directus";
import { caseStudiesFallback, caseStudiesOrder } from "../../lib/case-studies-data";

const cmsCases = await getCaseStudies();
const cases = cmsCases.length > 0
  ? cmsCases
  : caseStudiesOrder.map(slug => caseStudiesFallback[slug]);
---

<Layout title="Case Studies | DigiPub" description="Einblicke in unsere Projekte: Markenaufbau, SEO, Designsysteme, Automatisierung und KI.">

  <!-- Hero -->
  <section class="bg-white py-16 text-center border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-4">Einblicke in unsere Arbeit</p>
      <h1 class="text-5xl md:text-7xl font-semibold text-[#1a1a1a] tracking-tight mb-4">Case Studies</h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto">
        Wie Unternehmen mit DigiPub sichtbarer, klarer und digitaler werden.
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {cases.map(cs => (
          <a href={`/case-studies/${cs.slug}`} class="group bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
            {cs.hero_image
              ? <img src={getAssetUrl(cs.hero_image, 800)} alt={cs.title} class="w-full aspect-video object-cover" loading="lazy" />
              : <div class="w-full aspect-video bg-gray-100 flex items-center justify-center">
                  <span class="text-gray-300 text-sm font-mono">Bild folgt</span>
                </div>
            }
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {cs.tags.split(',').map(t => (
                  <span class="text-xs font-mono text-gray-400 uppercase tracking-widest">{t.trim()}</span>
                ))}
              </div>
              <h2 class="font-semibold text-[#1a1a1a] text-lg leading-snug mb-2 group-hover:opacity-70 transition-opacity">{cs.title}</h2>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">{cs.excerpt}</p>
              <div class="flex gap-4 text-xs text-gray-400">
                <span>{cs.kunde}</span>
                <span>·</span>
                <span>{cs.branche}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>
