---
import Layout from "../../layouts/Layout.astro";
import { getCaseStudy } from "../../lib/directus";
import { caseStudiesFallback, caseStudiesOrder } from "../../lib/case-studies-data";
import CaseStudyHero from "../../components/case-studies/CaseStudyHero.astro";
import CaseStudyContent from "../../components/case-studies/CaseStudyContent.astro";
import CaseStudyIntroText from "../../components/case-studies/CaseStudyIntroText.astro";
import DarkCTA from "../../components/DarkCTA.astro";

export async function getStaticPaths() {
  return caseStudiesOrder.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const cms = await getCaseStudy(slug);
const d = cms ?? caseStudiesFallback[slug];

if (!d) return Astro.redirect('/case-studies');

const heroFallbacks: Record<string, string> = {
  "smart-catering":    "/images/case-studies/smart-catering-hero.jpg",
  "portazon":          "/images/case-studies/portazon-hero.png",
  "haidacher":         "/images/case-studies/haidacher-hero.png",
  "walter-de-gruyter": "/images/case-studies/degruyter-hero.png",
};

const logoFallbacks: Record<string, string> = {
  "smart-catering":    "/images/case-studies/smart-catering-logo.jpeg",
  "portazon":          "/images/case-studies/portazon-logo.png",
  "haidacher":         "/images/referenzen/haidacher.webp",
  "walter-de-gruyter": "/images/case-studies/degruyter-logo.jpg",
};
---

<Layout title={`${d.title} | DigiPub`} description={d.excerpt}>

  <CaseStudyHero
    title={d.title}
    subtitle={d.subtitle}
    description={d.description}
    kunde={d.kunde}
    branche={d.branche}
    tags={d.tags}
    heroImageId={d.hero_image}
    heroImageFallback={heroFallbacks[slug] ?? "/images/case-studies/smart-catering-hero.jpg"}
    kundeLogoId={d.kunde_logo}
  />

  {d.intro_text && <CaseStudyIntroText text={d.intro_text} />}

  <CaseStudyContent
    ausgangslageText={d.ausgangslage_text}
    logoSrc={logoFallbacks[slug]}
    kundeName={d.kunde}
    zielesLeftTitle={d.ziele_left_title}
    zielesLeftText={d.ziele_left_text}
    zielesRightTitle={d.ziele_right_title}
    zielesRightText={d.ziele_right_text}
    vorgehenItems={d.vorgehen_items}
    ergebnisText={d.ergebnis_text}
    learningsText={d.learnings_text}
    kpis={d.kpis}
  />

  <DarkCTA />

</Layout>
