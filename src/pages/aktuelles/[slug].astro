---
import Layout from "../../layouts/Layout.astro";
import { getPosts, getPost } from "../../lib/directus";

export async function getStaticPaths() {
  const posts = await getPosts(100);
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getPost(slug!);
if (!post) return Astro.redirect("/aktuelles");
---
<Layout title={`${post.title} | DigiPub`} description={post.excerpt}>
  <article class="bg-white">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <a href="/aktuelles" class="text-xs text-gray-400 hover:text-gray-700 mb-8 block">← Aktuelles</a>
      <h1 class="text-4xl md:text-5xl font-semibold text-[#1a1a1a] tracking-tight mb-6">{post.title}</h1>
      <p class="text-xl text-gray-500 leading-relaxed mb-12 border-b border-gray-100 pb-12">{post.excerpt}</p>
      {post.cover_image && <img src={`https://directus.deutsche-musik.de/assets/${post.cover_image}?width=1200&format=webp`} alt={post.title} class="w-full rounded-xl mb-12" />}
      <div class="prose prose-gray max-w-none" set:html={post.content} />
    </div>
  </article>
</Layout>
