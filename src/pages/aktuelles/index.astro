---
import Layout from "../../layouts/Layout.astro";
import { getPosts } from "../../lib/directus";
const posts = await getPosts(20);
---
<Layout title="Aktuelles | DigiPub">
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-5xl md:text-6xl font-semibold text-[#1a1a1a] tracking-tight mb-4">Aktuelles</h1>
      <p class="text-gray-500 text-xl mb-16">Erkenntnisse in Praxis.</p>
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/aktuelles/${post.slug}`} class="group border border-gray-100 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
              {post.cover_image && <img src={`https://directus.deutsche-musik.de/assets/${post.cover_image}?width=600&format=webp`} alt={post.title} class="w-full aspect-video object-cover" loading="lazy" />}
              <div class="p-6">
                <p class="font-mono text-xs text-gray-400 mb-3">{new Date(post.date_created).toLocaleDateString("de-DE",{day:"2-digit",month:"short",year:"numeric"})}{post.read_time && ` · ${post.read_time} min`}</p>
                <h2 class="text-lg font-semibold text-[#1a1a1a] group-hover:text-gray-600 transition-colors mb-2 leading-snug">{post.title}</h2>
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{post.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="border border-dashed border-gray-200 rounded-xl p-20 text-center">
          <p class="text-gray-300 font-mono text-sm">Beiträge werden aus Directus geladen.</p>
          <p class="text-gray-200 font-mono text-xs mt-2">Collection: digipub_posts</p>
        </div>
      )}
    </div>
  </section>
</Layout>
