---
import Layout from "../../layouts/Layout.astro";
import { getLeistung } from "../../lib/directus";
import { leistungenFallback } from "../../lib/leistungen-data";
import LeistungHero from "../../components/leistungen/LeistungHero.astro";
import LeistungIntro from "../../components/leistungen/LeistungIntro.astro";
import KeyTakeaways from "../../components/leistungen/KeyTakeaways.astro";
import LeistungSektionen from "../../components/leistungen/LeistungSektionen.astro";
import UnserAnsatz from "../../components/leistungen/UnserAnsatz.astro";
import LeistungKacheln from "../../components/leistungen/LeistungKacheln.astro";
import WiesoDigiPub from "../../components/leistungen/WiesoDigiPub.astro";
import FinalCTA from "../../components/leistungen/FinalCTA.astro";

const slug = "designsystem";
const cms = await getLeistung(slug);
const d = cms ?? leistungenFallback[slug];
---

<Layout
  title="Designsystem | Konsistenz über alle Touchpoints | DigiPub"
  description="Vom Mehrwert zur konsistenten Gestaltung. Skalierbare Designsysteme, die Marken stärken und Teams schneller machen."
>
  <LeistungHero
    number={d.number}
    title={d.title}
    subtitle={d.subtitle}
    heroText={d.hero_text}
  />

  <LeistungIntro
    title={d.intro_title}
    text1={d.intro_text_1}
    bold={d.intro_bold}
    text2={d.intro_text_2}
    imageId={d.intro_image}
    imageFallback="/images/leistungen/designsystem-hero.png"
    imageAlt="Designsystem Konsistenz"
  />

  <KeyTakeaways items={d.key_takeaways} />

  <LeistungSektionen
    section1={{
      title: d.section1_title,
      text: d.section1_text,
      bold: d.section1_bold,
      imageId: d.section1_image,
      imageFallback: "/images/leistungen/designsystem-section1.png",
      imageAlt: "Multibrand Designsystem",
    }}
    section2={{
      title: d.section2_title,
      text: d.section2_text,
      bold: d.section2_bold,
      imageId: d.section2_image,
      imageFallback: "/images/leistungen/designsystem-hero.png",
      imageAlt: "Designsystem vs UI-Kit",
    }}
  />

  <UnserAnsatz
    title={d.ansatz_title}
    text1={d.ansatz_text_1}
    text2={d.ansatz_text_2}
    bold={d.ansatz_bold}
  />

  <LeistungKacheln title={d.leistungen_title} cards={d.leistungen_cards} />

  <WiesoDigiPub
    title={d.wieso_title}
    subtitle={d.wieso_subtitle}
    items={d.wieso_items}
  />

  <FinalCTA />
</Layout>
