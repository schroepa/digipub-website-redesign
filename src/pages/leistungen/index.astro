---
import Layout from "../../layouts/Layout.astro";

const leistungen = [
  { num:"01", title:"Marken-Aufbau / Branding", slug:"markenaufbau-branding", teaser:"Markenaufbau neu gedacht", desc:"Wir helfen Unternehmen, ihren echten Mehrwert strategisch, digital und über alle Touchpoints hinweg sichtbar zu machen.", img:"https://www.digipub.de/wp-content/uploads/2025/11/u2637499129_Aufsteigende_Digitale_Treppe_in_den_Himmel_-ar_1_82697a3c-1fc2-462e-9cb1-95b02a9d72c2_1-1024x574.png" },
  { num:"02", title:"SEO / GEO", slug:"seo-geo", teaser:"Sichtbarkeit in KI-Zeiten", desc:"KI verändert die Suche. Wir verbinden klassische SEO mit Generative Engine Optimization.", img:"https://www.digipub.de/wp-content/uploads/2025/11/u2637499129_Aufsteigende_Digitale_Treppe_in_den_Himmel_-ar_1_1092d6df-3801-4deb-af05-16387df12f0c_0-1024x574.png" },
  { num:"03", title:"Designsystem", slug:"designsystem", teaser:"Konsistenz als System", desc:"Ein Designsystem macht Struktur sichtbar – über alle Anwendungen hinweg konsistent.", img:"https://www.digipub.de/wp-content/uploads/2025/11/u2637499129_Netzwerk_aus_Knoten_und_Kanten_in_Wolkenform_-ar_e39ad9a2-5a17-4a91-a5d9-f27d771febfe_2-1024x574.png" },
  { num:"04", title:"Automatisierung", slug:"automatisierung", teaser:"Weniger Routine, mehr Fokus", desc:"Mit n8n verbinden wir Systeme, digitalisieren Routineaufgaben und schaffen messbare Entlastung.", img:"https://www.digipub.de/wp-content/uploads/2025/11/u2637499129_httpss.mj_.runp0dDZhJI-sA_Bitte_ein_Agent_workflow_75aa457d-7289-4910-8b5c-85549dd31453_0-1024x574.png" },
  { num:"05", title:"KI-Implementierung", slug:"ki-implementierung", teaser:"KI beginnt mit der richtigen Frage", desc:"Echte Wirkung entsteht durch den gezielten Einsatz von KI. Wir identifizieren passende Use Cases.", img:"https://www.digipub.de/wp-content/uploads/2025/11/u2637499129_digitale_Matrix_dreht_sich_um_zufriedenen_Nutzer__083b13f9-3139-4de5-9ac3-47d2e29efa3c_0-1024x574.png" },
];
---

<Layout title="Leistungen | DigiPub" description="Fünf Leistungsfelder: Markenaufbau, SEO/GEO, Designsystem, Automatisierung und KI-Implementierung.">
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-5xl md:text-6xl font-semibold text-[#1a1a1a] tracking-tight mb-4">Leistungen</h1>
      <p class="text-gray-500 text-xl mb-16">Fünf Hebel. Ein Ziel: Mehrwert.</p>

      <div class="divide-y divide-gray-100">
        {leistungen.map((l) => (
          <a href={`/leistungen/${l.slug}`} class="group grid grid-cols-1 md:grid-cols-3 gap-6 py-10 items-center hover:bg-gray-50 transition-colors -mx-4 px-4 rounded-xl">
            <div class="flex items-start gap-4">
              <span class="font-mono text-xs text-gray-300 mt-1 shrink-0">{l.num}</span>
              <div>
                <p class="text-xs text-gray-400 mb-1">{l.teaser}</p>
                <h2 class="text-xl font-semibold text-[#1a1a1a] group-hover:text-gray-600 transition-colors">{l.title}</h2>
              </div>
            </div>
            <p class="text-gray-500 text-sm leading-relaxed">{l.desc}</p>
            <div class="flex items-center justify-end gap-4">
              <img src={l.img} alt={l.title} class="w-28 h-16 object-cover rounded-lg opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" />
              <svg class="text-gray-300 group-hover:text-[#1a1a1a] transition-colors shrink-0" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
