---
import Layout from "../../layouts/Layout.astro";
import { getLeistung } from "../../lib/directus";
import { leistungenFallback, leistungenOrder } from "../../lib/leistungen-data";
import LeistungTagsNav from "../../components/leistungen/LeistungTagsNav.astro";
import LeistungHero from "../../components/leistungen/LeistungHero.astro";
import LeistungIntro from "../../components/leistungen/LeistungIntro.astro";
import KeyTakeaways from "../../components/leistungen/KeyTakeaways.astro";
import TitelBalken from "../../components/leistungen/TitelBalken.astro";
import VertiefungsKacheln from "../../components/leistungen/VertiefungsKacheln.astro";
import UnserAnsatz from "../../components/leistungen/UnserAnsatz.astro";
import StatementBar from "../../components/leistungen/StatementBar.astro";
import SimpleCTA from "../../components/leistungen/SimpleCTA.astro";
import LeistungKacheln from "../../components/leistungen/LeistungKacheln.astro";
import WiesoDigiPub from "../../components/leistungen/WiesoDigiPub.astro";
import FaqAkkordeon from "../../components/produkte/FaqAkkordeon.astro";
import CalendlySection from "../../components/leistungen/CalendlySection.astro";

const slug = "automatisierung";
const cms = await getLeistung(slug);
const d = cms ?? leistungenFallback[slug];
const _idx = leistungenOrder.indexOf(slug);
const prevSlug = _idx > 0 ? leistungenOrder[_idx - 1] : null;
const nextSlug = _idx >= 0 ? leistungenOrder[(_idx + 1) % leistungenOrder.length] : null;
const prevHref = prevSlug ? `/leistungen/${prevSlug}` : null;
const nextHref = nextSlug ? `/leistungen/${nextSlug}` : null;
---

<Layout
  title="Prozess-Automatisierung | Mehr Zeit für das Wesentliche | DigiPub"
  description="Automatisierung hilft Unternehmen, Zeit zu sparen, Qualität zu sichern und Engpässe zu lösen."
>
  <LeistungHero
    number={d.number}
    breadcrumb={d.breadcrumb}
    prevHref={prevHref}
    nextHref={nextHref}
    title={d.title}
    subtitle={d.subtitle}
    heroText={d.hero_text}
    heroText2={d.intro_text_2}
  />

  <LeistungTagsNav introLabel={d.nav_intro_label || d.breadcrumb || d.title} />

  <LeistungIntro
    imageId={d.intro_image}
    imageFallback="/images/leistungen/automatisierung-hero.png"
    imageAlt="Prozess-Automatisierung"
  />

  <KeyTakeaways items={d.key_takeaways} variant="table" />

  <TitelBalken title={d.intro_title} />

  <VertiefungsKacheln
    left={{ title: d.section1_title, text: d.section1_text, bold: d.section1_bold }}
    right={{ title: d.section2_title, text: d.section2_text, bold: d.section2_bold }}
  />

  <UnserAnsatz
    title={d.ansatz_title}
    text1={d.ansatz_text_1}
    text2={d.ansatz_text_2}
    imageId={d.ansatz_image}
    imageFallback="https://www.digipub.de/wp-content/uploads/2026/01/u2637499129_httpss.jpg"
    imageAlt="Unser Ansatz Automatisierung"
  />

  <StatementBar text={d.ansatz_bold} />
  <SimpleCTA />
  <LeistungKacheln title={d.leistungen_title} cards={d.leistungen_cards} />
  {d.leistungen_cards_2 && d.leistungen_cards_2.length > 0 && (
    <LeistungKacheln title={d.leistungen_title_2 || ''} cards={d.leistungen_cards_2} />
  )}
  <WiesoDigiPub title={d.wieso_title} subtitle={d.wieso_subtitle} items={d.wieso_items} />
  {d.faq_items && d.faq_items.length > 0 && (
    <section class="border-y border-border bg-background">
      <div class="mx-auto max-w-3xl px-6 py-20">
        <FaqAkkordeon items={d.faq_items.map((f) => ({ frage: f.question, antwort: f.answer }))} />
      </div>
    </section>
  )}
  <CalendlySection />
</Layout>
