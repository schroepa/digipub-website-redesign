---
import Layout from "../../layouts/Layout.astro";

const sections = [
  { id: "intro", label: "Markenaufbau heute" },
  { id: "takeaways", label: "Key Takeaways" },
  { id: "digital", label: "Digital gedacht" },
  { id: "ansatz", label: "Unser Ansatz" },
  { id: "leistungen", label: "Leistungen" },
  { id: "wieso", label: "Wieso DigiPub?" },
];
---

<Layout
  title="Markenaufbau mit System | Mehrwert ist Marke | DigiPub"
  description="Gemeinsam machen wir Ihren Mehrwert zur Marke – verständlich, konsistent und vertrauenswürdig über alle Touchpoints."
>

  <!-- INTRO: H1+H2 voll, 2 Spalten Text darunter -->
  <section id="intro" class="bg-white pt-16 pb-12">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/leistungen" class="text-sm text-gray-400 hover:text-gray-700 mb-10 block">← Leistungen</a>
      <h1 class="text-4xl md:text-6xl font-bold text-[#1a1a1a] tracking-tight mb-3">
        Digitaler Markenaufbau heute
      </h1>
      <h2 class="text-2xl text-gray-500 font-normal mb-10">Warum moderne Markenführung digitaler wird</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <p class="text-lg text-gray-700 leading-relaxed">
          Markenaufbau heute bedeutet, den echten Mehrwert eines Unternehmens über <strong>alle analogen und digitalen Touchpoints</strong> hinweg sichtbar, erlebbar und vertrauenswürdig zu machen.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed">
          Unternehmen, die ihre Marke neu ausrichten, verbinden <strong>Strategie, Design, Sprache und digitale Prozesse</strong> zu einem System, das Wiedererkennbarkeit schafft, Vertrauen stärkt und Wachstum fördert.
        </p>
      </div>
    </div>
  </section>

  <!-- STICKY NAV -->
  <nav class="sticky top-16 z-40 bg-white border-y border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex gap-1 overflow-x-auto py-3 scrollbar-hide">
        {sections.map((s) => (
          <a
            href={`#${s.id}`}
            class="shrink-0 px-4 py-1.5 text-sm text-gray-500 hover:text-[#1a1a1a] hover:bg-gray-100 rounded-full transition-colors whitespace-nowrap"
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- HERO IMAGE -->
  <section class="bg-white py-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="https://www.digipub.de/wp-content/uploads/2025/11/u2637499129_Aufsteigende_Digitale_Treppe_in_den_Himmel_-ar_1_82697a3c-1fc2-462e-9cb1-95b02a9d72c2_1.png"
          alt="Der Digitale Markenaufbau"
          class="w-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- KEY TAKEAWAYS -->
  <section id="takeaways" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
      <div class="md:col-span-2">
        <h2 class="text-3xl font-bold text-[#1a1a1a] mb-8">Key-Takeaways</h2>
        <ul class="space-y-4">
          {[
            ["Markenaufbau bedeutet heute:", "den echten Mehrwert eines Unternehmens sichtbar, verständlich und vertrauenswürdig zu machen."],
            ["Digitaler Wandel & Marke sind untrennbar:", "Jede Veränderung in Prozessen, Services oder Strukturen formt auch die Außenwirkung."],
            ["Mehrwert ist Marke:", "Eine starke Marke entsteht dort, wo Nutzen, Zielgruppenverständnis und klare Kommunikation zusammenkommen."],
            ["Konsistenz über alle Touchpoints:", "Design, Sprache und digitale Systeme müssen eine erkennbare, glaubwürdige Welt erzeugen."],
            ["Vertrauen als Kern:", "Durch klare Positionierung, relevante Inhalte und EEAT-/GEO-Prinzipien entsteht Autorität im Markt."],
          ].map(([bold, text]) => (
            <li class="flex gap-3 items-start">
              <span class="text-gray-400 mt-1">•</span>
              <p class="text-gray-700 leading-relaxed"><strong class="text-[#1a1a1a]">{bold}</strong> {text}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-2xl p-8 text-center flex flex-col items-center justify-center gap-4" style="background:#1a1a1a; min-height: 280px;">
        <p class="text-[#d97706] font-bold text-lg">Mehrwert ist Marke</p>
        <a
          href="mailto:kontakt@digipub.de"
          class="border-2 border-[#d97706] rounded-xl px-8 py-6 text-[#d97706] font-bold text-3xl hover:bg-[#d97706] hover:text-[#1a1a1a] transition-colors w-full text-center"
        >
          Erzähl<br />mal!
        </a>
      </div>
    </div>
  </section>

  <!-- GRAUER BANNER: Markenaufbau muss digital gedacht werden! -->
  <section class="py-8" style="background:#f0f0f0;">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-[#1a1a1a]">Markenaufbau muss digital gedacht werden!</h2>
    </div>
  </section>

  <!-- 2 WEISSE KACHELN -->
  <section id="digital" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white rounded-2xl shadow-md p-8">
        <h3 class="text-xl font-bold text-[#1a1a1a] mb-4">Markenaufbau als Transformationsprozess</h3>
        <p class="text-gray-700 leading-relaxed mb-4">
          Unternehmen, die bisher vor allem analoge Produkte oder Dienstleistungen anbieten, stehen vor einem tiefgreifenden Wandel: Digitalisierung verändert Strukturen, Prozesse, Kundenverhalten und damit zwangsläufig die Marke.
        </p>
        <p class="text-gray-700 leading-relaxed">
          Markenaufbau ist deshalb mehr als Logo und Kommunikation. Er ist ein <strong>Transformationsprozess</strong>, der Außenwirkung und Innenleben des Unternehmens miteinander verbindet.
        </p>
      </div>
      <div class="bg-white rounded-2xl shadow-md p-8">
        <h3 class="text-xl font-bold text-[#1a1a1a] mb-4">Markenbildung als Übersetzungsleistung</h3>
        <p class="text-gray-700 leading-relaxed mb-4">Digitale Systeme, Automatisierung und KI erzeugen eine Rückkopplung in die Organisation:</p>
        <ul class="space-y-2 mb-4">
          {["Teams arbeiten anders","Entscheidungen werden datengetriebener","Kundenerwartungen steigen","Kommunikation wird schneller, spezifischer, personalisierter"].map((item) => (
            <li class="flex gap-2 text-gray-700">
              <span>•</span> {item}
            </li>
          ))}
        </ul>
        <p class="text-gray-700 leading-relaxed">
          Markenbildung übersetzt diese Veränderungen in <strong>klare Positionierung</strong>, <strong>passende Sprache</strong>, <strong>kohärentes Design</strong> und <strong>spürbaren Mehrwert</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- UNSER ANSATZ: weiße Kachel links + Bild rechts -->
  <section id="ansatz" class="bg-white py-8 pb-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <div class="bg-white rounded-2xl shadow-md p-8">
        <h3 class="text-2xl font-bold text-[#1a1a1a] mb-4">Unser Ansatz</h3>
        <p class="text-gray-700 leading-relaxed mb-4">Markenaufbau beginnt beim <strong>Verstehen</strong>:</p>
        <ul class="space-y-2 mb-6">
          {["Was ist der echte Mehrwert?","Wer sind die Menschen dahinter?","Welche Zielgruppe soll erreicht werden","Welche Sprache spricht die Zielgruppe?","Welche Prozesse, Produkte oder digitalen Services prägen die Marke heute und in Zukunft?"].map((item) => (
            <li class="flex gap-2 text-gray-700">
              <span>•</span> {item}
            </li>
          ))}
        </ul>
        <p class="text-gray-700 leading-relaxed">
          Diese Fragen stammen aus der strategischen SEO- und GEO-Arbeit, denn Sichtbarkeit entsteht dort, wo <strong>Relevanz</strong>, <strong>Nutzerintention</strong> und <strong>Markenversprechen</strong> übereinstimmen.
        </p>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="https://www.digipub.de/wp-content/uploads/2026/01/u2637499129_Aufsteigende_Digitale_Treppe_in_den_Himmel.jpg"
          alt="Unser Ansatz"
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- DUNKLER BANNER: Daraus entsteht... -->
  <section class="py-10" style="background:#1a1a1a;">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="text-[#d97706] text-xl md:text-2xl font-bold">
        Daraus entsteht eine Marke, die authentisch, nutzerzentriert und zukunftsfähig ist.
      </p>
    </div>
  </section>

  <!-- DU? + ERZÄHL MAL! -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="border-2 border-gray-200 rounded-2xl p-10 flex flex-col items-center justify-center text-center">
        <p class="text-xl text-[#1a1a1a] mb-2">Wer kennt deinen Mehrwert besser als</p>
        <p class="text-7xl font-black text-[#1a1a1a]">DU?</p>
      </div>
      <div class="rounded-2xl p-8 flex flex-col items-center justify-center text-center gap-4" style="background:#1a1a1a;">
        <p class="text-[#d97706] font-bold text-lg">Wir hören erstmal zu</p>
        <a
          href="mailto:kontakt@digipub.de"
          class="border-2 border-[#d97706] rounded-xl px-8 py-6 text-[#d97706] font-bold text-3xl hover:bg-[#d97706] hover:text-[#1a1a1a] transition-colors w-full"
        >
          Erzähl<br />mal!
        </a>
      </div>
    </div>
  </section>

  <!-- GRAUER BANNER: Leistungen im Markenaufbau -->
  <section class="py-10" style="background:#f0f0f0;">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-black text-[#1a1a1a]">Leistungen im Markenaufbau</h2>
    </div>
  </section>

  <!-- 6 WEISSE LEISTUNGS-KACHELN -->
  <section id="leistungen" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
      {[
        {
          title: "Strategische Markenentwicklung",
          intro: "Wir definieren die Grundlagen für eine starke, klare Positionierung:",
          items: ["Werte, Mission, Vision","Markenversprechen & Nutzerargumentation","Wettbewerb & Alleinstellung (USP / UVP)","Leitplanken für Kommunikation, Tonalität und Markenverhalten","Übertragung in digitale Angebote, Touchpoints und Services"],
          ziel: "Die Marke erhält einen Kompass, der intern wie extern Orientierung schafft."
        },
        {
          title: "Visuelle Identität & digitales Designsystem",
          intro: "Eine starke Marke braucht eine visuelle Sprache, die Wiedererkennung erzeugt, analog und digital. Wir entwickeln.",
          items: ["Logo & Markenzeichen","Farb- & Formwelten","Typografie","Iconografie & Bildstil","Komponenten für Websites, mobile Anwendungen und digitale Plattformen","Regeln für KI-generierte Bilder, damit sie authentisch, konsistent und nicht austauschbar wirken"],
          ziel: "Eine konsistente, funktionale Markenwelt, die auf allen Kanälen einheitlich wirkt."
        },
        {
          title: "Marken-Kommunikation & Zielgruppen-Ansprache",
          intro: "Marke wird durch Sprache erlebbar. Wir entwickeln eine Kommunikation, die präzise auf Zielgruppen abgestimmt ist:",
          items: ["Tonalitätsleitfäden","Argumentationslinien für Entscheidungsträger (B2B) und Konsumenten (B2C)","Nutzenbotschaften, die echten Mehrwert klar formulieren","Storytelling, das die reale Identität des Unternehmens sichtbar macht","Guidelines für KI-gestützte Contentproduktion (Stimme, Stil, Narrative)"],
          ziel: "Eine Sprache, die Vertrauen aufbaut und die Zielgruppe emotional wie rational abholt."
        },
        {
          title: "Zielgruppenrelevanz & Nutzerzentrierung",
          intro: "Markenaufbau ist nur erfolgreich, wenn die Botschaft die Menschen trifft, für die sie gemacht ist. Wir analysieren:",
          items: ["Bedürfnisse & Erwartungen","Mediennutzung","Entscheidungsverhalten","Barrieren & Pain Points","Chancen für personalisierte Kommunikation"],
          ziel: "Die Marke spricht die Sprache der Zielgruppe, nicht die des Unternehmens. Stichwort: Interner Sprech
        },
        {
          title: "Vertrauen, Autorität & Erfahrung (SEO/GEO & EEAT)",
          intro: "Vertrauen ist heute ein technisches und inhaltliches Thema. Wir entwickeln Marken so, dass sie auch für Suchmaschinen, KI-Suchsysteme und Bewertungsalgorithmen vertrauenswürdig wirken:",
          items: ["EEAT (Experience, Expertise, Authoritativeness, Trustworthiness)","GEO (Generative Engine Optimization)","Social Proof, Cases, Referenzen","Konsistente Datenstruktur (Schema, Knowledge Panels, digitale Identität)","Guidelines für Content, der KI-Antwortsysteme zuverlässig bedient"],
          ziel: "Die Marke wird sichtbar, glaubwürdig und relevant, für Menschen und Maschinen."
        },
        {
          title: "Markenbekanntheit & nachhaltige Sichtbarkeit",
          intro: "Wir begleiten die Marke auf dem Weg zum Markt:",
          items: ["Storylines für Social Media & PR","Einführungskampagnen","Contentstrategien","Employer Branding und interne Kommunikation","Erfolgsmessung & datenbasierte Optimierung"],
          ziel: "Die Marke verankert sich langfristig im Markt und im Gedächtnis der Zielgruppe."
        },
      ].map((l) => (
        <div class="bg-white rounded-2xl shadow-md p-8 flex flex-col">
          <h3 class="text-xl font-bold text-[#1a1a1a] mb-3">{l.title}</h3>
          <p class="text-gray-700 mb-3 leading-relaxed">{l.intro}</p>
          <ul class="space-y-2 mb-6 flex-1">
            {l.items.map((item) => (
              <li class="flex gap-2 text-gray-700">
                <span>•</span> <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="font-bold text-[#1a1a1a] border-t border-gray-100 pt-4">Ziel: {l.ziel}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- GRAUER BANNER: Wieso mit DigiPub? -->
  <section id="wieso" class="py-10" style="background:#f0f0f0;">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-[#1a1a1a] mb-4">Wieso mit DigiPub?</h2>
      <p class="text-gray-700 leading-relaxed max-w-4xl">
        Markenaufbau heute bedeutet, den echten Mehrwert eines Unternehmens sichtbar, erlebbar und vertrauenswürdig zu machen, über alle analogen und digitalen Touchpoints hinweg. Unternehmen, die ihre Marke neu ausrichten, verbinden Strategie, Design, Sprache und digitale Prozesse zu einem System, das Wiedererkennbarkeit schafft, Vertrauen stärkt und Wachstum fördert.
      </p>
    </div>
  </section>

  <!-- 6 DUNKLE KACHELN -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        ["Wir teilen Wissen,", "statt es in Silos zu halten."],
        ["Mitarbeitende wachsen", "aktiv mit."],
        ["Ein echtes Gegenüber", "für nachhaltige Weiterentwicklung."],
        ["Wir arbeiten vom", "aktuellen Reifegrad aus."],
        ["Tiefe Zusammenarbeit", "verbessert Prozesse nachhaltig."],
        ["Gemeinsame Entwicklung", "statt Ergebnisübergabe."],
      ].map(([line1, line2]) => (
        <div class="rounded-2xl p-8 text-center flex items-center justify-center min-h-[160px]" style="background:#1a1a1a;">
          <p class="text-[#d97706] font-bold text-lg leading-snug">
            <strong>{line1}</strong><br />{line2}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- FINAL: DU? + CALENDLY -->
  <section class="bg-white py-8 pb-16">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Links: DU? Box -->
      <div class="border-2 border-gray-200 rounded-2xl p-10 flex flex-col items-center justify-between text-center gap-8">
        <div>
          <p class="text-xl text-[#1a1a1a] mb-2">Wer kennt deinen Mehrwert besser als</p>
          <p class="text-7xl font-black text-[#1a1a1a]">DU?</p>
        </div>
        <div>
          <p class="text-gray-500 mb-4">Was ist dein Projekt?</p>
          <a href="mailto:kontakt@digipub.de" class="inline-block px-6 py-3 bg-gray-200 hover:bg-gray-300 text-[#1a1a1a] font-medium rounded-lg transition-colors mb-8">
            Kontakt aufnehmen
          </a>
          <div class="mt-4">
            <img src="https://www.digipub.de/wp-content/uploads/2021/07/DIGI_PUB1.png" alt="DigiPub" class="h-16 mx-auto opacity-60" />
          </div>
        </div>
      </div>
      <!-- Rechts: Calendly -->
      <div class="border-2 border-gray-200 rounded-2xl p-8">
        <p class="font-semibold text-[#1a1a1a] mb-4 text-center">Buche ein kostenloses Erstgespräch</p>
        <div
          class="calendly-inline-widget"
          data-url="https://calendly.com/nigronet?embed_domain=www.digipub.de&embed_type=Inline"
          style="min-width:280px;height:500px;"
        ></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      </div>
    </div>
  </section>

</Layout>
