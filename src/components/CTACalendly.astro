---
const calendlyUrl = "https://calendly.com/nigronet";
---

<section class="bg-gray-50 border-t border-gray-200 py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl">

      <p class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-4">
        N&auml;chster Schritt
      </p>
      <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] leading-snug mb-4">
        Lass uns reden.
      </h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Kein Pitch, kein Angebot beim ersten Gespr&auml;ch.
        Wir h&ouml;ren erst zu &ndash; dann reden wir &uuml;ber L&ouml;sungen.
      </p>

      <!-- Two buttons side by side -->
      <div class="flex flex-wrap gap-3">
        <!-- Primary: Calendly popup -->
        <a
          href={calendlyUrl}
          onclick={`Calendly.initPopupWidget({url:'${calendlyUrl}'});return false;`}
          class="inline-flex items-center gap-2 px-6 py-3 text-white text-sm font-semibold rounded-lg hover:opacity-80 transition-opacity"
          style="background:#1a1a1a;"
        >
          Termin buchen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </a>

        <!-- Secondary: Email -->
        <a
          href="mailto:kontakt@digipub.de"
          class="inline-flex items-center gap-2 px-6 py-3 text-[#1a1a1a] text-sm font-semibold rounded-lg border border-gray-300 hover:border-[#1a1a1a] transition-colors"
        >
          E-Mail schreiben
        </a>
      </div>

    </div>
  </div>
</section>

<!-- Calendly popup CSS + JS -->
<link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
<script src="https://assets.calendly.com/assets/external/widget.js" async></script>
