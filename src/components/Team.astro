---
const team = [
  {
    name: "Nicolas Grossman",
    rolle: "Founder",
    bio: "Ich habe DigiPub 2015 gegr&uuml;ndet, weil mir eine Sache immer wieder aufgefallen ist: Viele Unternehmen haben echten Mehrwert &ndash; aber keine Sprache daf&uuml;r. Das wollte ich &auml;ndern. Heute bauen wir Marken, Systeme und Strukturen, die f&uuml;r sich selbst sprechen.",
    foto: "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&q=80",
    linkedin: "https://www.linkedin.com/company/digipub-de/",
  },
  {
    name: "Patrick Schr&ouml;dter",
    rolle: "Digital Strategy",
    bio: "Ich bringe Struktur in komplexe digitale Projekte &ndash; von SEO-Strategie &uuml;ber KI-Integration bis zur Automatisierung. Was mich antreibt: der Moment, in dem ein gut durchdachtes System anf&auml;ngt, f&uuml;r sich selbst zu arbeiten.",
    foto: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80",
    linkedin: "https://www.linkedin.com/company/digipub-de/",
  },
];
---

<section class="bg-white py-20 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-6">

    <div class="mb-12">
      <p class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-3">Hinter DigiPub</p>
      <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] leading-snug">
        Wir sind DigiPub.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {team.map((person) => (
        <div class="flex gap-6 items-start">

          <!-- Kleines Foto -->
          <div class="shrink-0 w-20 h-20 rounded-xl overflow-hidden shadow-sm">
            <img
              src={person.foto}
              alt={person.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Text -->
          <div>
            <p class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-1">
              {person.rolle}
            </p>
            <h3 class="font-semibold text-[#1a1a1a] text-lg mb-2" set:html={person.name} />
            <p class="text-gray-600 text-sm leading-relaxed mb-3" set:html={person.bio} />
            <a
              href={person.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="inline-flex text-gray-400 hover:text-[#2563eb] transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
