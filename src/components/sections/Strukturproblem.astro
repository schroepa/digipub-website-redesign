---
import Section from "../ui/Section.astro";

const patterns = [
  "Inhalte, die über Jahre gewachsen sind – ohne roten Faden.",
  "Zielgruppen, die nicht klar voneinander getrennt adressiert werden.",
  "Navigationen, die die interne Struktur spiegeln, nicht die Fragen der Besucher.",
  "Prozesse, die nicht sauber ineinandergreifen.",
  "Ein Mehrwert, der intern selbstverständlich ist – aber nach außen nicht ankommt.",
];
---

<Section id="strukturproblem">
  <div class="grid gap-x-16 gap-y-12 lg:grid-cols-[0.85fr_1.15fr]">
    <!-- Linke Spalte: Kicker + Headline -->
    <div class="lg:sticky lg:top-28 lg:self-start">
      <p
        data-animate
        class="mb-6 font-mono text-xs uppercase tracking-[0.2em] text-primary"
        style="opacity: 0; transform: translateY(30px);"
      >
        <span class="text-muted-foreground">02</span> &nbsp;·&nbsp; Das Strukturproblem
      </p>
      <h2
        data-animate
        class="font-bold text-foreground"
        style="font-size: var(--text-section); line-height: 1.08; letter-spacing: -0.02em; opacity: 0; transform: translateY(30px);"
      >
        Warum gute Unternehmen<br />digital unsichtbar bleiben.
      </h2>
    </div>

    <!-- Rechte Spalte: Muster-Liste -->
    <div>
      <p
        data-animate
        class="mb-2 text-muted-foreground"
        style="font-size: var(--text-body); opacity: 0; transform: translateY(30px);"
      >
        Es sind fast immer dieselben Muster:
      </p>

      <ul class="mt-2">
        {patterns.map((pattern, i) => (
          <li
            data-animate
            class="grid grid-cols-[auto_1fr] items-baseline gap-5 border-t border-border py-6"
            style="opacity: 0; transform: translateY(30px);"
          >
            <span class="font-mono text-xs text-muted-foreground tabular-nums">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span
              class="text-foreground"
              style="font-size: var(--text-body); line-height: 1.55;"
            >
              {pattern}
            </span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Schlusspunkt – nimmt den Druck raus -->
  <div class="mt-[var(--peak-space)] border-t border-border pt-12">
    <p
      data-statement
      class="max-w-3xl font-bold text-foreground"
      style="font-size: var(--text-peak); line-height: 1.25; letter-spacing: -0.01em;"
    >
      Das ist kein Versagen. Das ist das, was passiert, wenn ein Unternehmen
      wächst – und die digitale Struktur nicht mitgewachsen ist.
    </p>
  </div>
</Section>

<script>
  import { initScrollAnimate } from "../../lib/scrollAnimate";
  import { initWordReveal } from "../../lib/wordReveal";

  const section = document.getElementById("strukturproblem");
  if (section) initScrollAnimate(section);

  const statement = document.querySelector<HTMLElement>(
    "#strukturproblem [data-statement]",
  );
  if (statement) initWordReveal(statement);
</script>
