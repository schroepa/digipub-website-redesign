---
import Section from "../ui/Section.astro";

const steps = [
  { title: "Mehrwert erkennen", sub: "Was steckt wirklich dahinter?" },
  { title: "Mehrwert ordnen", sub: "Wie wird es kommunizierbar?" },
  { title: "Mehrwert sichtbar machen", sub: "Über welche Kanäle und Systeme?" },
  { title: "Mehrwert automatisieren", sub: "Was soll dauerhaft und skalierbar laufen?" },
];

// Position jedes Knotens entlang der Linie (0..1).
const at = (i: number) => i / (steps.length - 1);
---

<Section id="reihenfolge" class="border-t border-border">
  <div class="max-w-3xl">
    <p
      data-animate
      class="mb-6 font-mono text-xs uppercase tracking-[0.2em] text-primary"
      style="opacity: 0; transform: translateY(30px);"
    >
      <span class="text-muted-foreground">04</span> &nbsp;·&nbsp; Die Reihenfolge
    </p>
    <h2
      data-animate
      class="font-bold text-foreground"
      style="font-size: var(--text-section); line-height: 1.08; letter-spacing: -0.02em; opacity: 0; transform: translateY(30px);"
    >
      Die Reihenfolge entscheidet.
    </h2>
  </div>

  <!-- ── Signatur: Vier-Stufen-Flussdiagramm mit Flow-Line ──────────────── -->
  <div style="margin-top: clamp(48px, 7vw, 96px);">
    <!-- Desktop: horizontale Kette -->
    <div class="hidden lg:block">
      <div data-flow class="relative mb-7 flex items-center" style="height: 14px;">
        <div
          data-flow-line
          data-dir="h"
          class="absolute top-1/2 -translate-y-1/2"
          style="left: 12.5%; right: 12.5%;"
        ></div>
        <div class="relative grid w-full grid-cols-4">
          {steps.map((_, i) => (
            <div class="flex justify-center">
              <span data-flow-node data-at={at(i)}></span>
            </div>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-4 gap-6">
        {steps.map((step, i) => (
          <div data-animate style="opacity: 0; transform: translateY(30px);">
            <span class:list={["block font-mono text-sm tabular-nums mb-3", i === 0 ? "text-primary" : "text-muted-foreground"]}>
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="font-bold text-foreground mb-1" style="font-size: var(--text-body); line-height: 1.25;">
              {step.title}
            </h3>
            <p class="text-muted-foreground" style="font-size: var(--text-body); line-height: 1.5;">
              {step.sub}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: vertikale Kette -->
    <ol data-flow class="relative lg:hidden">
      <div
        data-flow-line
        data-dir="v"
        class="absolute"
        style="left: 6px; top: 6px; bottom: 6px;"
      ></div>
      {steps.map((step, i) => (
        <li class="relative pb-10 pl-9 last:pb-0">
          <span data-flow-node data-at={at(i)} class="absolute left-0 top-1"></span>
          <span class:list={["block font-mono text-sm tabular-nums mb-2", i === 0 ? "text-primary" : "text-muted-foreground"]}>
            {String(i + 1).padStart(2, "0")}
          </span>
          <h3 class="font-bold text-foreground mb-1" style="font-size: var(--text-body); line-height: 1.25;">
            {step.title}
          </h3>
          <p class="text-muted-foreground" style="font-size: var(--text-body); line-height: 1.5;">
            {step.sub}
          </p>
        </li>
      ))}
    </ol>
  </div>

  <!-- Positionierungs-Statement – kein CTA, den Gedanken sacken lassen -->
  <div class="mt-[var(--peak-space)]">
    <p
      data-statement
      class="max-w-3xl font-bold text-foreground"
      style="font-size: var(--text-statement); line-height: 1.2; letter-spacing: -0.02em;"
    >
      Andere beginnen bei Schritt drei. Wir beginnen bei Schritt eins.
    </p>
  </div>
</Section>

<script>
  import { initScrollAnimate } from "../../lib/scrollAnimate";
  import { initWordReveal } from "../../lib/wordReveal";
  import { initFlowLines } from "../../lib/flowLine";

  const section = document.getElementById("reihenfolge");
  if (section) {
    initScrollAnimate(section);
    initFlowLines(section, { durationMs: 1700 });
  }

  const statement = document.querySelector<HTMLElement>(
    "#reihenfolge [data-statement]",
  );
  if (statement) initWordReveal(statement);
</script>
