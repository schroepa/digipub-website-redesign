---
import Section from "../ui/Section.astro";

const questions = [
  "Was leistet dein Unternehmen wirklich?",
  "Wen willst du erreichen – und mit welchem Mehrwert?",
  "Was existiert bereits, was fehlt, was bremst?",
];
---

<Section id="denkweise" class="border-t border-border">
  <div class="max-w-3xl">
    <p
      data-animate
      class="mb-6 font-mono text-xs uppercase tracking-[0.2em] text-primary"
      style="opacity: 0; transform: translateY(30px);"
    >
      <span class="text-muted-foreground">03</span> &nbsp;·&nbsp; Die Denkweise
    </p>
    <h2
      data-animate
      class="font-bold text-foreground"
      style="font-size: var(--text-section); line-height: 1.08; letter-spacing: -0.02em; opacity: 0; transform: translateY(30px);"
    >
      Wir beginnen nicht mit Maßnahmen.<br />Wir beginnen mit dem Verstehen.
    </h2>

    <p
      data-animate
      class="mt-8 text-muted-foreground"
      style="font-size: var(--text-body); line-height: 1.7; opacity: 0; transform: translateY(30px);"
    >
      Bevor irgendwas gebaut, geschrieben oder automatisiert wird, stellen wir
      dieselben Fragen:
    </p>
  </div>

  <!-- Die drei Fragen – groß, als Denkprozess gesetzt -->
  <ol class="mt-12 max-w-4xl">
    {questions.map((question, i) => (
      <li
        data-animate
        class="grid grid-cols-[auto_1fr] items-baseline gap-6 border-t border-border py-7"
        style="opacity: 0; transform: translateY(30px);"
      >
        <span class="font-mono text-sm text-primary tabular-nums">
          {String(i + 1).padStart(2, "0")}
        </span>
        <span
          class="font-medium text-foreground"
          style="font-size: var(--text-peak); line-height: 1.2; letter-spacing: -0.01em;"
        >
          {question}
        </span>
      </li>
    ))}
  </ol>

  <p
    data-animate
    class="mt-10 font-mono text-sm text-muted-foreground"
    style="opacity: 0; transform: translateY(30px);"
  >
    → Erst danach entstehen Lösungen.
  </p>

  <!-- Abgrenzungssatz – allein, mutig -->
  <div class="mt-[var(--peak-space)]">
    <p
      data-statement
      class="max-w-3xl font-bold text-foreground"
      style="font-size: var(--text-statement); line-height: 1.2; letter-spacing: -0.02em;"
    >
      Die meisten fangen bei den Maßnahmen an. Wir fangen davor an.
    </p>
  </div>
</Section>

<script>
  import { initScrollAnimate } from "../../lib/scrollAnimate";
  import { initWordReveal } from "../../lib/wordReveal";

  const section = document.getElementById("denkweise");
  if (section) initScrollAnimate(section);

  const statement = document.querySelector<HTMLElement>(
    "#denkweise [data-statement]",
  );
  if (statement) initWordReveal(statement);
</script>
