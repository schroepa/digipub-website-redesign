---
import ThemeToggle from "./ThemeToggle.astro";

const nav = [
  {
    label: "Leistungen",
    href: "/leistungen",
    children: [
      { label: "Marken-Aufbau / Branding", href: "/leistungen/markenaufbau-branding" },
      { label: "SEO / GEO", href: "/leistungen/seo-geo" },
      { label: "Designsystem", href: "/leistungen/designsystem" },
      { label: "Automatisierung", href: "/leistungen/automatisierung" },
      { label: "KI-Implementierung", href: "/leistungen/ki-implementierung" },
    ],
  },
  { label: "Case Studies", href: "/case-studies" },
  { label: "Referenzen", href: "/referenzen" },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-background sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img src="/logo.svg" alt="DigiPub" class="h-6 w-auto" />
    </a>

    <!-- Desktop Nav (zentriert) -->
    <nav class="hidden md:flex items-center gap-1 absolute left-1/2 -translate-x-1/2">
      {nav.map((item) => (
        <div class="relative group">
          <a
            href={item.href}
            class={`px-4 py-2 text-sm rounded transition-colors flex items-center gap-1
              ${currentPath.startsWith(item.href) ? "text-foreground bg-accent font-medium" : "text-muted-foreground hover:text-foreground hover:bg-accent"}`}
          >
            {item.label}
            {item.children && (
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
          {item.children && (
            <div class="absolute top-full left-0 pt-1 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-150">
              <div class="bg-popover rounded-lg p-1 min-w-[220px] shadow-xl border border-border">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class={`block px-3 py-2 text-sm rounded transition-colors
                      ${currentPath === child.href ? "text-foreground bg-accent font-medium" : "text-muted-foreground hover:text-foreground hover:bg-accent"}`}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Theme Toggle (Desktop) -->
    <div class="hidden md:block">
      <ThemeToggle />
    </div>

    <!-- Kontakt CTA (Desktop) -->
    <a
      href="/kontakt"
      class="hidden md:inline-flex items-center px-5 py-2 text-sm font-medium bg-foreground text-background rounded hover:opacity-80 transition-opacity"
    >
      Kontakt
    </a>

    <!-- Hamburger Button (Mobile) -->
    <button id="mob-btn" class="md:hidden p-2 text-muted-foreground relative w-9 h-9 flex items-center justify-center" aria-label="Menü öffnen">
      <span class="hamburger-icon absolute inset-0 flex flex-col items-center justify-center gap-[5px] transition-opacity duration-200">
        <span class="block w-5 h-[2px] bg-current"></span>
        <span class="block w-5 h-[2px] bg-current"></span>
        <span class="block w-5 h-[2px] bg-current"></span>
      </span>
      <span class="close-icon absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </span>
    </button>
  </div>
</header>

<!-- Mobile Fullscreen Overlay -->
<div
  id="mob-menu"
  class="md:hidden fixed inset-0 z-40 bg-background flex flex-col px-6 pt-24 pb-12"
  style="opacity:0; pointer-events:none; transform: translateY(-8px); transition: opacity 0.25s ease, transform 0.25s ease;"
>
  <nav class="flex flex-col gap-1 flex-1">
    {nav.map((item) => (
      <div class="mob-item">
        <a
          href={item.href}
          class={`block py-3 text-2xl font-semibold border-b border-border transition-colors
            ${currentPath.startsWith(item.href) ? "text-foreground" : "text-foreground hover:text-muted-foreground"}`}
        >
          {item.label}
        </a>
        {item.children && (
          <div class="flex flex-col pl-4 pt-1 pb-2 gap-0.5">
            {item.children.map((child) => (
              <a
                href={child.href}
                class={`py-1.5 text-sm transition-colors
                  ${currentPath === child.href ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground"}`}
              >
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>

  <div class="mt-auto flex flex-col gap-3">
    <div class="flex justify-center">
      <ThemeToggle />
    </div>
    <a
      href="/kontakt"
      class="block text-center px-5 py-3.5 text-sm font-medium bg-foreground text-background rounded hover:opacity-80 transition-opacity"
    >
      Kontakt
    </a>
  </div>
</div>

<script>
  const btn = document.getElementById("mob-btn");
  const menu = document.getElementById("mob-menu") as HTMLElement;
  const hamburger = btn?.querySelector(".hamburger-icon") as HTMLElement;
  const close = btn?.querySelector(".close-icon") as HTMLElement;

  let open = false;

  btn?.addEventListener("click", () => {
    open = !open;

    if (open) {
      menu.style.opacity = "1";
      menu.style.pointerEvents = "auto";
      menu.style.transform = "translateY(0)";
      hamburger.style.opacity = "0";
      close.style.opacity = "1";
      document.body.style.overflow = "hidden";
    } else {
      menu.style.opacity = "0";
      menu.style.pointerEvents = "none";
      menu.style.transform = "translateY(-8px)";
      hamburger.style.opacity = "1";
      close.style.opacity = "0";
      document.body.style.overflow = "";
    }
  });
</script>
