---
// Keine Props – identisch auf allen Leistungsseiten
---
<section class="bg-gray-50 border-y border-gray-200">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 rounded-xl overflow-hidden shadow-sm border border-gray-200">

      <!-- Links: DU? -->
      <div class="bg-white p-8 md:p-10 flex flex-col justify-center">
        <p class="text-gray-500 mb-1">Wer kennt deinen Mehrwert besser als</p>
        <p class="font-black text-[#1a1a1a]" style="font-size:5rem;line-height:1;">DU?</p>
      </div>

      <!-- Rechts: Erzähl mal! -->
      <a
        href="mailto:kontakt@digipub.de"
        style="background:#1a1a1a;"
        class="group p-8 md:p-10 flex flex-col justify-center hover:opacity-90 transition-opacity"
      >
        <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color:#d97706;">Wir hören erstmal zu</p>
        <span
          style="border:1px solid #d97706;"
          class="inline-flex items-center gap-2 px-6 py-3 text-2xl font-semibold rounded w-fit text-[#d97706] group-hover:bg-[#d97706] group-hover:text-[#1a1a1a] transition-colors"
        >
          Erzähl mal!
        </span>
      </a>

    </div>
  </div>
</section>
