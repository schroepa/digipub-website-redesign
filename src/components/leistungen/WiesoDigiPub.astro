---
import type { WiesoItem } from "../../lib/directus";

interface Props {
  title: string;
  subtitle: string;
  items: WiesoItem[];
}
const { title, subtitle, items } = Astro.props;
---
<section id="section-wieso" style="background:#1a1a1a;">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-semibold text-white mb-4">{title}</h2>
    <p class="text-white/60 leading-relaxed max-w-3xl mb-10">{subtitle}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {items.map((item) => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex items-center justify-center min-h-[120px] text-center hover:border-white/30 transition-colors">
          <p class="text-white font-semibold leading-snug">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
