---
import { getAssetUrl } from "../../lib/directus";

interface Props {
  title: string;
  text1: string;
  bold: string;
  text2: string;
  imageId?: string;
  imageFallback: string;
  imageAlt: string;
}
const { title, text1, bold, text2, imageId, imageFallback, imageAlt } = Astro.props;
const imgSrc = imageId ? getAssetUrl(imageId, 1024) : imageFallback;
---
<!-- Hero-Bild: eigenständig, zentriert, volle Breite -->
<section class="bg-white pt-16 pb-0">
  <div class="max-w-7xl mx-auto px-6">
    <div class="rounded-xl overflow-hidden shadow-md">
      <img src={imgSrc} alt={imageAlt} class="w-full object-cover max-h-[480px]" loading="eager" />
    </div>
  </div>
</section>

<!-- Intro-Text -->
<section id="section-einleitung" class="bg-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-4 leading-snug">{title}</h2>
      <p class="text-gray-600 leading-relaxed mb-4">{text1}</p>
      <p class="font-semibold text-[#1a1a1a] mb-4">{bold}</p>
      <p class="text-gray-600 leading-relaxed">{text2}</p>
    </div>
  </div>
</section>
