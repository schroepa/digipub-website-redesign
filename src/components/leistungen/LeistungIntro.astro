---
import { getAssetUrl } from "../../lib/directus";

interface Props {
  title: string;
  text1: string;
  bold: string;
  text2: string;
  imageId?: string;
  imageFallback: string;
  imageAlt: string;
}
const { title, text1, bold, text2, imageId, imageFallback, imageAlt } = Astro.props;
const imgSrc = imageId ? getAssetUrl(imageId, 1024) : imageFallback;
---
<section class="bg-white">
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-4 leading-snug">{title}</h2>
        <p class="text-gray-600 leading-relaxed mb-4">{text1}</p>
        <p class="font-semibold text-[#1a1a1a] mb-6">{bold}</p>
        <p class="text-gray-600 leading-relaxed">{text2}</p>
      </div>
      <div class="rounded-xl overflow-hidden shadow-md">
        <img src={imgSrc} alt={imageAlt} class="w-full object-cover" loading="eager" />
      </div>
    </div>
  </div>
</section>
