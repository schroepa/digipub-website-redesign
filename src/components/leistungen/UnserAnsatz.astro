---
import { getAssetUrl } from "../../lib/directus";

interface Props {
  title: string;
  text1: string;   // Intro-Satz + Bullets ("- " Prefix)
  text2: string;   // Abschluss-Paragraph
  imageId?: string;
  imageFallback: string;
  imageAlt: string;
}
const { title, text1, text2, imageId, imageFallback, imageAlt } = Astro.props;
const imgSrc = imageId ? getAssetUrl(imageId, 1024) : imageFallback;

function renderText(text: string) {
  const lines = text.split('\n').filter(l => l.trim());
  const segments: Array<{ type: 'text' | 'bullets' | 'numbered'; items: string[] }> = [];
  let currentBullets: string[] = [];
  let currentNumbered: string[] = [];

  for (const line of lines) {
    const trimmed = line.trimStart();
    if (trimmed.startsWith('- ')) {
      if (currentNumbered.length) { segments.push({ type: 'numbered', items: [...currentNumbered] }); currentNumbered = []; }
      currentBullets.push(trimmed.slice(2));
    } else if (/^\d+\.\s/.test(trimmed)) {
      if (currentBullets.length) { segments.push({ type: 'bullets', items: [...currentBullets] }); currentBullets = []; }
      currentNumbered.push(trimmed.replace(/^\d+\.\s/, ''));
    } else {
      if (currentBullets.length) { segments.push({ type: 'bullets', items: [...currentBullets] }); currentBullets = []; }
      if (currentNumbered.length) { segments.push({ type: 'numbered', items: [...currentNumbered] }); currentNumbered = []; }
      segments.push({ type: 'text', items: [line] });
    }
  }
  if (currentBullets.length) segments.push({ type: 'bullets', items: currentBullets });
  if (currentNumbered.length) segments.push({ type: 'numbered', items: currentNumbered });
  return segments;
}
---

<section id="section-ansatz" class="bg-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-stretch">

      <!-- Text links -->
      <div>
        <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-6 leading-snug">{title}</h2>
        {renderText(text1).map(seg =>
          seg.type === 'bullets'
            ? <ul class="list-disc list-outside pl-5 space-y-2 text-gray-600 leading-relaxed mb-4">
                {seg.items.map(item => <li class="pl-1">{item}</li>)}
              </ul>
            : seg.type === 'numbered'
            ? <ol class="list-decimal list-outside pl-5 space-y-2 text-gray-600 leading-relaxed mb-4">
                {seg.items.map(item => <li class="pl-1">{item}</li>)}
              </ol>
            : <p class="text-gray-600 leading-relaxed mb-4">{seg.items[0]}</p>
        )}
        {text2 && <p class="text-gray-600 leading-relaxed mt-2">{text2}</p>}
      </div>

      <!-- Bild rechts -->
      <div class="rounded-xl overflow-hidden shadow-md h-full">
        <img src={imgSrc} alt={imageAlt} class="w-full h-full object-cover" loading="lazy" />
      </div>

    </div>
  </div>
</section>
