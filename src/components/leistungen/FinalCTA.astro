---
// Keine Props – dieser Block ist auf allen Leistungsseiten identisch
---
<section id="section-kontakt" class="bg-gray-50 border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-2 gap-8">

    <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100 flex flex-col items-center justify-between gap-6 text-center">
      <div>
        <p class="text-gray-500 mb-2">Wer kennt deinen Mehrwert besser als</p>
        <p class="font-black text-[#1a1a1a]" style="font-size:5rem;line-height:1;">DU?</p>
      </div>
      <div style="width:100%">
        <p class="text-gray-400 text-sm mb-4">Was ist dein Projekt?</p>
        <a href="mailto:kontakt@digipub.de" style="background:#1a1a1a;" class="inline-flex items-center gap-2 px-5 py-2.5 text-white text-sm font-medium rounded hover:opacity-80 transition-opacity mb-6">
          Kontakt aufnehmen
        </a>
        <div>
          <img src="https://www.digipub.de/wp-content/uploads/2021/07/DIGI_PUB1.png" alt="DigiPub" class="h-12 opacity-40 mx-auto" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <p class="font-semibold text-[#1a1a1a] mb-4 text-center">Kostenloses Erstgespräch buchen</p>
      <div
        class="calendly-inline-widget"
        data-url="https://calendly.com/nigronet?embed_domain=www.digipub.de&embed_type=Inline"
        style="min-width:280px;height:500px;"
      ></div>
      <script is:inline type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
    </div>

  </div>
</section>
