---
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  items: FaqItem[];
  title?: string;
}
const { items, title = "Häufige Fragen" } = Astro.props;
if (!items || items.length === 0) return;
---

<section id="section-faq" class="bg-gray-50 border-y border-gray-200">
  <div class="max-w-7xl mx-auto px-6 py-20">

    <div class="max-w-3xl mx-auto">
      <p class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-4">FAQ</p>
      <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-12 leading-snug">{title}</h2>

      <div class="space-y-0" id="faq-list">
        {items.map((item, i) => (
          <div class="faq-item border-t border-gray-200">
            <button
              class="faq-trigger w-full flex items-center justify-between gap-6 py-5 text-left group"
              aria-expanded="false"
              data-index={i}
            >
              <span class="font-medium text-[#1a1a1a] group-hover:text-gray-700 transition-colors leading-snug">
                {item.question}
              </span>
              <span class="faq-icon shrink-0 w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center transition-all group-hover:border-gray-400">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path class="faq-plus" d="M6 2v8M2 6h8" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
                  <path class="faq-minus hidden" d="M2 6h8" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
            <div class="faq-answer hidden pb-5 pr-12">
              <div class="rich-text text-gray-600 leading-relaxed" set:html={item.answer} />
            </div>
          </div>
        ))}
        <div class="border-t border-gray-200"></div>
      </div>
    </div>

  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>(".faq-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const item = btn.closest(".faq-item")!;
      const answer = item.querySelector(".faq-answer")!;
      const plus = item.querySelector(".faq-plus")!;
      const minus = item.querySelector(".faq-minus")!;
      const isOpen = btn.getAttribute("aria-expanded") === "true";

      // Alle anderen schließen
      document.querySelectorAll(".faq-item").forEach((other) => {
        if (other !== item) {
          other.querySelector(".faq-answer")?.classList.add("hidden");
          other.querySelector(".faq-trigger")?.setAttribute("aria-expanded", "false");
          other.querySelector(".faq-plus")?.classList.remove("hidden");
          other.querySelector(".faq-minus")?.classList.add("hidden");
          (other.querySelector(".faq-icon") as HTMLElement)?.style.setProperty("background", "");
        }
      });

      if (isOpen) {
        answer.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        plus.classList.remove("hidden");
        minus.classList.add("hidden");
        (item.querySelector(".faq-icon") as HTMLElement).style.background = "";
      } else {
        answer.classList.remove("hidden");
        btn.setAttribute("aria-expanded", "true");
        plus.classList.add("hidden");
        minus.classList.remove("hidden");
        (item.querySelector(".faq-icon") as HTMLElement).style.background = "#1a1a1a";
        (item.querySelector(".faq-icon svg path") as SVGPathElement)?.setAttribute("stroke", "white");
      }
    });
  });
</script>
