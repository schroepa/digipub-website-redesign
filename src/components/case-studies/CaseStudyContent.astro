---
import type { VorgehenItem, KPI } from "../../lib/directus";

interface Props {
  ausgangslageText: string;
  logoSrc?: string;
  kundeName: string;
  zielesLeftTitle: string; zielesLeftText: string;
  zielesRightTitle: string; zielesRightText: string;
  vorgehenItems: VorgehenItem[];
  ergebnisText: string;
  learningsText?: string;
  kpis: KPI[];
}
const { ausgangslageText, logoSrc, kundeName, zielesLeftTitle, zielesLeftText, zielesRightTitle, zielesRightText, vorgehenItems, ergebnisText, learningsText, kpis } = Astro.props;

function renderText(text: string, dark = false) {
  const lines = text.split('\n').filter(l => l.trim());
  const out: Array<{type:'text'|'bullets', items:string[]}> = [];
  let bullets: string[] = [];
  for (const l of lines) {
    if (l.trimStart().startsWith('- ')) { bullets.push(l.trimStart().slice(2)); }
    else { if (bullets.length) { out.push({type:'bullets',items:[...bullets]}); bullets=[]; } out.push({type:'text',items:[l]}); }
  }
  if (bullets.length) out.push({type:'bullets',items:bullets});
  return { segments: out, dark };
}

const ulClass       = (dark: boolean, sm = false) => `list-disc pl-5 space-y-1.5 leading-relaxed mb-4 ${sm ? 'text-sm' : ''} ${dark ? 'text-white/60' : 'text-gray-600'}`;
const liClass       = "pl-1";
const pClass        = (dark: boolean, sm = false) => `leading-relaxed mb-3 ${sm ? 'text-sm' : ''} ${dark ? 'text-white/60' : 'text-gray-600'}`;
---

<!-- Ausgangslage -->
<section class="bg-gray-50 border-y border-gray-200">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="flex items-center justify-center">
        {logoSrc
          ? <img src={logoSrc} alt={kundeName} class="max-h-32 max-w-[280px] w-auto object-contain" loading="lazy" />
          : <div class="w-full h-32 bg-gray-200 rounded-lg flex items-center justify-center"><span class="text-gray-400 text-sm font-medium">{kundeName}</span></div>
        }
      </div>
      <div>
        <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-6">Ausgangslage</h2>
        {renderText(ausgangslageText).segments.map(s =>
          s.type === 'bullets'
            ? <ul class={ulClass(false)}>{s.items.map(i => <li class={liClass}>{i}</li>)}</ul>
            : <p class={pClass(false)}>{s.items[0]}</p>
        )}
      </div>
    </div>
  </div>
</section>

<!-- Ziele -->
<section class="bg-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-10">Ziele der Maßnahmen</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
        <h3 class="font-semibold text-[#1a1a1a] mb-4">{zielesLeftTitle}</h3>
        {renderText(zielesLeftText).segments.map(s =>
          s.type === 'bullets'
            ? <ul class={ulClass(false, true)}>{s.items.map(i => <li class={liClass}>{i}</li>)}</ul>
            : <p class={pClass(false, true)}>{s.items[0]}</p>
        )}
      </div>
      <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
        <h3 class="font-semibold text-[#1a1a1a] mb-4">{zielesRightTitle}</h3>
        {renderText(zielesRightText).segments.map(s =>
          s.type === 'bullets'
            ? <ul class={ulClass(false, true)}>{s.items.map(i => <li class={liClass}>{i}</li>)}</ul>
            : <p class={pClass(false, true)}>{s.items[0]}</p>
        )}
      </div>
    </div>
  </div>
</section>

<!-- Vorgehen -->
<section style="background:#1a1a1a;">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-semibold text-white mb-10">Unser Vorgehen</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {vorgehenItems.map((item, i) => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-white/30 transition-colors">
          <div class="flex items-start gap-4">
            <span class="text-xs font-mono text-gray-500 mt-1 shrink-0">{String(i+1).padStart(2,'0')}</span>
            <div class="flex-1">
              <h3 class="font-semibold text-white mb-3">{item.title}</h3>
              {renderText(item.text, true).segments.map(s =>
                s.type === 'bullets'
                  ? <ul class={ulClass(true, true)}>{s.items.map(li => <li class={liClass}>{li}</li>)}</ul>
                  : <p class={pClass(true, true)}>{s.items[0]}</p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- KPIs -->
{kpis.length > 0 && (
  <section class="bg-gray-50 border-y border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {kpis.map(kpi => (
          <div class="text-center">
            <p class="text-3xl md:text-4xl font-black text-[#1a1a1a] mb-1">{kpi.value}</p>
            <p class="text-sm text-gray-500">{kpi.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Ergebnis -->
<section class="bg-white">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-semibold text-[#1a1a1a] mb-10">Ergebnis & Learnings</h2>
    <div class={`grid grid-cols-1 gap-8 ${learningsText ? 'md:grid-cols-2' : ''}`}>

      <!-- Ergebnis der Zusammenarbeit -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
        <h3 class="font-semibold text-[#1a1a1a] mb-4">Ergebnis der Zusammenarbeit</h3>
        {renderText(ergebnisText).segments.map(s =>
          s.type === 'bullets'
            ? <ul class={ulClass(false, true)}>{s.items.map(i => <li class={liClass}>{i}</li>)}</ul>
            : <p class={pClass(false, true)}>{s.items[0]}</p>
        )}
      </div>

      <!-- Learnings & Mehrwert -->
      {learningsText && (
        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <h3 class="font-semibold text-[#1a1a1a] mb-4">Learnings & Mehrwert</h3>
          {renderText(learningsText).segments.map(s =>
            s.type === 'bullets'
              ? <ul class={ulClass(false, true)}>{s.items.map(i => <li class={liClass}>{i}</li>)}</ul>
              : <p class={pClass(false, true)}>{s.items[0]}</p>
          )}
        </div>
      )}

    </div>
  </div>
</section>
