---
const logos = [
  { name: "Portazon", href: "/case-studies/portazon", file: "/images/referenzen/portazon.png" },
  { name: "Walter de Gruyter", href: "/case-studies/walter-de-gruyter", file: "/images/referenzen/walter-de-gruyter.jpg" },
  { name: "Smart Catering", href: "/case-studies/smart-catering", file: "/images/referenzen/sander-catering.jpg" },
  { name: "Tischlerei Haidacher", href: "/case-studies/haidacher", file: "/images/referenzen/haidacher.webp" },
  { name: "Cornelsen Verlag", href: "/referenzen", file: "/images/referenzen/cornelsen.jpg" },
  { name: "Westermann", href: "/referenzen", file: "/images/referenzen/westermann.png" },
  { name: "Edelman Deutschland", href: "/referenzen", file: "/images/referenzen/edelman.jpg" },
  { name: "A EINS Digital Innovation", href: "/referenzen", file: "/images/referenzen/aeins.jpeg" },
  { name: "Stadtwerke Trier", href: "/referenzen", file: "/images/referenzen/stadtwerke-trier.png" },
  { name: "Limebit", href: "/referenzen", file: "/images/referenzen/limebit.png" },
];
---

<section class="bg-white py-10">
  <div class="max-w-7xl mx-auto px-6">
    <p class="text-xs font-mono text-gray-400 uppercase tracking-widest mb-8">
      Unternehmen, die uns vertrauen
    </p>
  </div>

  <div class="logos-marquee">
    <div class="logos-track">
      {[...logos, ...logos].map((logo) => (
        <a
          href={logo.href}
          class="logos-item"
          style="filter: grayscale(1) opacity(0.45);"
          onmouseover="this.style.filter='grayscale(0) opacity(1)'"
          onmouseout="this.style.filter='grayscale(1) opacity(0.45)'"
        >
          <img
            src={logo.file}
            alt={logo.name}
            class="max-h-10 max-w-[140px] w-auto object-contain"
            loading="lazy"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .logos-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 5%,
      #000 95%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 5%,
      #000 95%,
      transparent
    );
  }

  .logos-track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: 4rem;
    padding-left: 1.5rem;
    animation: logos-scroll 40s linear infinite;
  }

  .logos-track:hover {
    animation-play-state: paused;
  }

  .logos-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    transition: filter 0.3s ease;
  }

  @keyframes logos-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 2rem));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logos-track {
      animation: none;
    }
  }
</style>
